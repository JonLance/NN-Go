/* This function runs once per frame, and is the heart of the program. */
SDL_AppResult SDL_AppIterate(void *appstate)
{
        Board *board = (Board *)appstate;
    // looking through the board
    for (int i = 0; i < BOARD_SIZE; i++) {
        for (int j = 0; j < BOARD_SIZE; j++) {
            // drawing the stones
            if (board->cells[i][j] == BLACK_STONE) {
                SDL_Rect rect = { i * CELL_SIZE, j * CELL_SIZE, CELL_SIZE, CELL_SIZE };
                SDL_RenderFillRect(renderer, &rect);
            } else if (board->cells[i][j] == WHITE_STONE) {
                SDL_Rect rect = { i * CELL_SIZE, j * CELL_SIZE, CELL_SIZE, CELL_SIZE };
                SDL_RenderFillRect(renderer, &rect);
            }

            // drawing the board cells
            if (board->cells[i][j] == EMPTY) {
                SDL_Rect rect = { i * CELL_SIZE, j * CELL_SIZE, CELL_SIZE, CELL_SIZE };
                SDL_RenderDrawRect(renderer, &rect);
            }

            // removing the stones if they are surrounded by a different color
            // should be fixed so that the stones of the same color are add there libitys to gether and not make them invisible
            if (board->cells[i][j] == BLACK_STONE && board->cells[i-1][j] == WHITE_STONE && board->cells[i+1][j] == WHITE_STONE && board->cells[i][j-1] == WHITE_STONE && board->cells[i][j+1] == WHITE_STONE) {
                SDL_Rect rect = { i * CELL_SIZE, j * CELL_SIZE, CELL_SIZE, CELL_SIZE };
                SDL_RenderDrawRect(renderer, &rect);
            }
            else if(board->cells[i][j] == WHITE_STONE && board->cells[i-1][j] == BLACK_STONE && board->cells[i+1][j] == BLACK_STONE && board->cells[i][j-1] == BLACK_STONE && board->cells[i][j+1] == BLACK_STONE) {
                SDL_Rect rect = { i * CELL_SIZE, j * CELL_SIZE, CELL_SIZE, CELL_SIZE };
                SDL_RenderDrawRect(renderer, &rect);
            }
        }
    }
    return SDL_APP_CONTINUE;
}

/* This function runs once at shutdown. */
void SDL_AppQuit(void *appstate, SDL_AppResult result)
{
    // removes the renderer and window, freeing up resources. at the end of the program.
    if (renderer) {
        SDL_DestroyRenderer(renderer);
        renderer = NULL;
    }
    if (window) {
        SDL_DestroyWindow(window);
        window = NULL;
    }

}
