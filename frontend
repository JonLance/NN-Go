        return SDL_APP_FAILURE;
    }

    // initializes the board to be empty.
    Board *board = new Board();
    for (int i = 0; i < BOARD_SIZE; i++) {
        for (int j = 0; j < BOARD_SIZE; j++) {
            board->cells[i][j] = EMPTY;
        }
    }
    board->turn = BLACK_TURN;
    board->score[0] = 0;
    board->score[1] = 0;
    board->lastMove[0] = -1;
    board->lastMove[1] = -1;
    *appstate = board;



    return SDL_APP_CONTINUE;
}

